# ============================================================
# SUPABASE (banco + storage)
# Pegue em: https://supabase.com/dashboard/project/_/settings/api
# e https://supabase.com/dashboard/project/_/settings/database
# ============================================================
# URL pública do projeto (https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# anon key (segura no client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service role key (NUNCA expor no client; uso apenas server-side)
SUPABASE_SERVICE_ROLE_KEY=
# Connection string (Postgres) – Transaction Pooler (porta 6543) para serverless/Vercel
DATABASE_URL=postgresql://postgres.PROJECT:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Direct URL (porta 5432) – usada por migrations/seed
DIRECT_URL=postgresql://postgres.PROJECT:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres

# Bucket do Supabase Storage para documentos
SUPABASE_STORAGE_BUCKET=documentos

# ============================================================
# AUTH (NextAuth)
# ============================================================
# Gere: openssl rand -base64 32
NEXTAUTH_SECRET=
# Em produção: https://seu-dominio.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# META GRAPH API
# https://developers.facebook.com/apps/
# ============================================================
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0
# System User Token com permissões: business_management,
# whatsapp_business_management, whatsapp_business_messaging
META_SYSTEM_USER_TOKEN=
# Verify token usado no webhook (string aleatória que você inventa)
META_WEBHOOK_VERIFY_TOKEN=
# (opcional) URL pública do webhook para registrar no app
META_WEBHOOK_CALLBACK_URL=

# ============================================================
# Flags
# ============================================================
NODE_ENV=development
