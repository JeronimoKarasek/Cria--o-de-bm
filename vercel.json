{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["gru1"],
  "functions": {
    "app/api/meta-api/import/route.ts": { "maxDuration": 60 },
    "app/api/meta-api/sync/route.ts": { "maxDuration": 60 },
    "app/api/meta-webhook/route.ts": { "maxDuration": 30 }
  }
}
